from sklearn.datasets import load_iris
import pandas as pd
import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt

# Load data
iris = load_iris(as_frame=True)
df = iris.frame
df.columns = ['sepal_length', 'sepal_width', 'petal_length', 'petal_width', 'species']

features = ['sepal_length', 'sepal_width', 'petal_length', 'petal_width']

# Q1: Statistics using NumPy
print("Q1 — Feature Statistics:")
print(f"{'Feature':<16} {'Mean':>8} {'Std':>8} {'Min':>8} {'Max':>8}")
for col in features:
    arr = df[col].values
    print(f"{col:<16} {np.mean(arr):>8.3f} {np.std(arr):>8.3f} "
          f"{np.min(arr):>8.3f} {np.max(arr):>8.3f}")

# Q2: Missing values
print("\nQ2 — Missing values per column:")
print(df.isnull().sum())

# Q3: Histograms (2x2 grid)
fig, axes = plt.subplots(2, 2, figsize=(10, 8))
for ax, col in zip(axes.flatten(), features):
    ax.hist(df[col], bins=20, color='steelblue', edgecolor='black')
    ax.set_title(col)
    ax.set_xlabel('Value')
    ax.set_ylabel('Frequency')
plt.suptitle('Iris Feature Distributions')
plt.tight_layout()
plt.show()

# Q4: Pairplot colored by species
sns.pairplot(df, hue='species', diag_kind='kde')
plt.suptitle('Iris Pairplot by Species', y=1.02)
plt.show()

# Q5: Correlation matrix (numeric features only)
corr = df[features].corr()
plt.figure(figsize=(7, 5))
sns.heatmap(corr, annot=True, cmap='coolwarm', fmt='.2f')
plt.title('Iris Feature Correlation Matrix')
plt.show()

# Q6: Analysis
print("\nQ6 — Analysis:")
print("Most correlated features:", end=" ")
corr_unstacked = corr.abs().unstack()
corr_unstacked = corr_unstacked[corr_unstacked < 1].sort_values(ascending=False)
top_pair = corr_unstacked.index[0]
print(f"{top_pair[0]} & {top_pair[1]} (r = {corr_unstacked.iloc[0]:.3f})")
print("Best feature to separate species: petal_length")
print("  → It shows the clearest separation across all 3 species in the pairplot.")
