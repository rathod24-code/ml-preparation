import numpy as np

def my_mean(data):
    return sum(data) / len(data)

def my_variance(data):
    mean = my_mean(data)
    return sum((x - mean) ** 2 for x in data) / len(data)

def my_std(data):
    return my_variance(data) ** 0.5

# Test data
normal_data  = [12, 15, 18, 14, 16, 13, 17, 19, 11, 20]
outlier_data = [12, 15, 18, 14, 16, 13, 17, 19, 11, 200]

for label, data in [("Normal", normal_data), ("With Outlier", outlier_data)]:
    print(f"\n--- {label} Data ---")
    m   = my_mean(data)
    var = my_variance(data)
    std = my_std(data)
    print(f"  My Mean     : {m:.4f}  | NumPy: {np.mean(data):.4f}")
    print(f"  My Variance : {var:.4f}  | NumPy: {np.var(data):.4f}")
    print(f"  My Std Dev  : {std:.4f}  | NumPy: {np.std(data):.4f}")

# BONUS: Z-scores for normal_data
m   = my_mean(normal_data)
std = my_std(normal_data)
z_scores = [(x - m) / std for x in normal_data]
print("\nZ-scores for normal_data:", [round(z, 2) for z in z_scores])
between_minus1_and_1 = sum(-1 <= z <= 1 for z in z_scores)
print(f"{between_minus1_and_1}/{len(z_scores)} values have Z-score between -1 and 1"
      f" ({100*between_minus1_and_1/len(normal_data):.0f}%) — expect ~68%")


