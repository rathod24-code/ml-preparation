import numpy as np

np.random.seed(42)
M = np.random.randn(4, 4)

# (1) Transpose
M_T = M.T
print("M Transpose:\n", M_T)
print("Shape of M.T:", M_T.shape)

# (2) M multiplied by its transpose
MMT = np.dot(M, M.T)
print("\nM · Mᵀ:\n", MMT)
print("Shape of M·Mᵀ:", MMT.shape)

# (3) Eigenvalues of M·Mᵀ
eigenvalues, eigenvectors = np.linalg.eig(MMT)
print("\nEigenvalues of M·Mᵀ:", eigenvalues)

# (4) Determinant
det = np.linalg.det(MMT)
print("\nDeterminant of M·Mᵀ:", det)

# Verify symmetry: A is symmetric if A == A.T
is_symmetric = np.allclose(MMT, MMT.T)
print("\nIs M·Mᵀ symmetric?", is_symmetric)

# BONUS: Normalize M so each row has unit length
norms = np.linalg.norm(M, axis=1, keepdims=True)
M_normalized = M / norms
row_magnitudes = np.linalg.norm(M_normalized, axis=1)
print("\nRow magnitudes after normalization (should all be 1.0):", row_magnitudes)


